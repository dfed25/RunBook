# Copy to `.env.local` and fill in values. Next.js loads `.env.local` automatically for `next dev` / `next build`.
# https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# Google Gemini (used by /api/chat, /api/tasks/generate, /api/lesson when not using static fallbacks)
GEMINI_API_KEY=
