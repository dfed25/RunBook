{
  "manifest_version": 3,
  "name": "Runbook",
  "version": "1.0",
  "description": "Onboarding copilot",
  "permissions": ["scripting"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["widget.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
